{
  "name": "harness-engineering",
  "version": "0.1.0",
  "description": "Harness Engineering - AI-Assisted Development Workflow",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "biome check --apply .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "dev": "tsc && node dist/server/index.js",
    "dev:watch": "tsc --watch",
    "start": "node dist/server/index.js",
    "pre-commit": "npm run check && npm run build",
    "verify": "npm run check && npm run build && npm run format:check",
    "ci-report": "node --loader ts-node/esm scripts/generate-ci-report.ts"
  },
  "keywords": ["harness", "engineering", "typescript"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.2",
    "husky": "^9.1.7",
    "live-server": "^1.2.2",
    "typescript": "^5.3.0"
  }
}
